{
  "permissions": {
    "allow": [
      "Bash(python scripts/*.py *)",
      "Bash(python ai_scientist/*.py *)",
      "Bash(nvidia-smi *)",
      "Bash(latexmk *)",
      "Bash(pdfinfo *)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "mcp__codex__codex",
      "mcp__codex__codex-reply"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pre-compact.py",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/post-compact-restore.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/experiment-safety-check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/notify.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
